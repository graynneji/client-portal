# Point this at the EXACT SAME database as the main trymentel.com app.
# This project only ever runs `prisma generate`, never `prisma migrate` —
# the main app owns all schema migrations.
DATABASE_URL=

# This app's own domain (used for building magic-link URLs and Paystack
# callback URLs).
NEXT_PUBLIC_APP_URL=https://app.trymentel.com

# Same Resend account as the main site (for magic-link emails).
RESEND_API_KEY=

# Same Paystack account as the main site — this is what lets a renewal
# paid here get picked up by the main app's existing Paystack webhook.
PAYSTACK_SECRET_KEY=

# A long random string, unique to this app, used to sign the client
# session cookie. Generate with: openssl rand -hex 32
CLIENT_SESSION_SECRET=

# Same Cal.com account as the main site (CAL_API_KEY). Create a SEPARATE
# event type in Cal.com dedicated to paid package sessions — keep it
# distinct from the free-consultation event type the main site uses for
# /book-call — and put its numeric event type ID below.
CAL_API_KEY=
CAL_SESSION_EVENT_TYPE_ID=
